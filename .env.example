# Portfolio Docs App - Environment Variables Contract
# Copy to .env.local for local development

# ============================================================================
# DEPLOYMENT CONFIGURATION
# ============================================================================

# Site URL (production)
# Used by: docusaurus.config.ts (url field)
# Local: http://localhost:3001
# Production: https://bryce.seefieldt.ca
DOCUSAURUS_SITE_URL=https://bryce.seefieldt.ca

# Base URL path
# Used by: docusaurus.config.ts (baseUrl field)
# Production: /docs/  (docs served under main portfolio domain)
# Standalone preview: /  (set this in Vercel preview env if needed)
DOCUSAURUS_BASE_URL=/docs/

# ============================================================================
# GITHUB INTEGRATION
# ============================================================================

# GitHub organization/user name
# Used by: docusaurus.config.ts (organizationName, links)
DOCUSAURUS_GITHUB_ORG=your-github-username

# GitHub repository name (portfolio-docs)
# Used by: docusaurus.config.ts (projectName, edit links)
DOCUSAURUS_GITHUB_REPO_DOCS=your-docs-repo-name

# GitHub repository name (portfolio-app)
# Used by: Custom fields for cross-linking
DOCUSAURUS_GITHUB_REPO_APP=your-app-repo-name

# ============================================================================
# PORTFOLIO APP INTEGRATION
# ============================================================================

# Portfolio App URL (for cross-linking from docs)
# Local: http://localhost:3000
# Production: https://bryce.seefieldt.ca
DOCUSAURUS_PORTFOLIO_APP_URL=https://bryce.seefieldt.ca

# ============================================================================
# OPTIONAL: FEATURE FLAGS & ANALYTICS
# ============================================================================

# Enable blog edit links (true/false)
# DOCUSAURUS_ENABLE_BLOG_EDIT=true

# Google Analytics measurement ID
# DOCUSAURUS_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# ============================================================================
# NOTES
# ============================================================================
# - All variables prefixed with DOCUSAURUS_ are exposed to client-side code
# - Non-prefixed variables are only available during build (server-side)
# - Create .env.local (gitignored) for local development overrides
# - Set these in Vercel dashboard for Preview and Production environments
# - See: https://docusaurus.io/docs/deployment#using-environment-variables
